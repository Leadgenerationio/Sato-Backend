# ─── Local sandbox environment ───
# Copy to .env.test for running tests against docker-compose.test.yml sandboxes.
# None of these values are secret — they only point at local containers.

PORT=3001
NODE_ENV=test
FRONTEND_URL=http://localhost:5173
JWT_SECRET=test-jwt-secret-min-32-chars-long-for-tests
JWT_REFRESH_SECRET=test-refresh-secret-min-32-chars-for-tests

# Postgres (docker-compose.test.yml)
DATABASE_URL=postgresql://stato:stato@localhost:5432/stato

# Redis (docker-compose.test.yml)
REDIS_URL=redis://localhost:6379

# MinIO — S3-compatible, stands in for Cloudflare R2
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=stato-test-key
R2_SECRET_ACCESS_KEY=stato-test-secret
R2_BUCKET=stato-test
R2_PUBLIC_URL=http://localhost:9000/stato-test
R2_ENDPOINT=http://localhost:9000

# DocuSign Developer Sandbox (demo.docusign.net)
# Fill from https://developers.docusign.com after following docs/SANDBOX-SETUP.md
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_REDIRECT_URI=http://localhost:3001/api/v1/integrations/docusign/callback
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_OAUTH_BASE=account-d.docusign.com

# LeadByte — mock mode (empty key keeps existing mock client)
LEADBYTE_API_KEY=
# Real base: https://clinical.leadbyte.co.uk/restapi/v1.3
# Localhost mock server during tests:
LEADBYTE_BASE_URL=http://localhost:8888

# Endole — mock mode
ENDOLE_API_KEY=

# Resend — mock mode (logs instead of sending when empty)
RESEND_API_KEY=
RESEND_FROM_EMAIL=test@stato.local
RESEND_FROM_NAME=Stato Test

# Xero — mock mode until Sam provides creds
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3001/api/v1/integrations/xero/callback
XERO_WEBHOOK_KEY=
