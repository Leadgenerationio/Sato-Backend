# ─── Core ───
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Generate prod values with: openssl rand -base64 32
# In NODE_ENV=production the server fails fast if these still equal the dev defaults.
JWT_SECRET=your-jwt-secret-min-32-chars-long-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long

# ─── Data stores ───
DATABASE_URL=postgresql://user:password@localhost:5432/stato
# When unset, all scheduled jobs (chase-overdue daily, leadbyte-sync /2min,
# catchr-sync hourly) are silently skipped — required for production.
REDIS_URL=redis://localhost:6379

# ─── Seed (only used by `npm run db:seed`) ───
# Set to "true" to seed Apex Media Ltd demo client + sample notifications.
# Leave unset in production.
SEED_DEMO_DATA=
SEED_OWNER_PASSWORD=
SEED_FINANCE_PASSWORD=
SEED_OPS_PASSWORD=
SEED_READONLY_PASSWORD=
SEED_DEMO_CLIENT_PASSWORD=

# ─── Xero (accounting) — Custom Connection ───
# developer.xero.com/app/manage → Stato Custom Connection
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_WEBHOOK_KEY=

# ─── LeadByte (lead generation) ───
LEADBYTE_API_KEY=
LEADBYTE_BASE_URL=https://clinical.leadbyte.co.uk/restapi/v1.3

# ─── Credit checks ───
# Auto-selected at runtime: Creditsafe > Endole > mock fallback.
ENDOLE_APP_ID=
ENDOLE_APP_KEY=
ENDOLE_BASE_URL=https://api.endole.co.uk
# Set to "true" for sandbox; leave unset for production billing-charged calls.
ENDOLE_SANDBOX=true
CREDITSAFE_API_KEY=
CREDITSAFE_BASE_URL=https://connect.creditsafe.com

# ─── Cloudflare R2 (file storage) ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=stato-production
R2_PUBLIC_URL=
R2_ENDPOINT=

# ─── Resend (transactional email) ───
RESEND_API_KEY=
# Must match a domain verified in Resend. `notifications@stato.local` is invalid.
RESEND_FROM_EMAIL=notifications@leadgeneration.io
RESEND_FROM_NAME=Stato Notifications

# ─── SignNow (e-signatures, replaces DocuSign) ───
# Default base URL is the production endpoint. Set api-eval.signnow.com for sandbox.
SIGNNOW_CLIENT_ID=
SIGNNOW_CLIENT_SECRET=
SIGNNOW_USERNAME=
SIGNNOW_PASSWORD=
SIGNNOW_BASE_URL=https://api.signnow.com
SIGNNOW_WEBHOOK_SECRET=

# ─── Catchr (ad-spend aggregation via MCP) ───
CATCHR_MCP_URL=https://api.catchr.io/mcp
CATCHR_ACCESS_TOKEN=
CATCHR_SYNC_BACKFILL_DAYS=30

# ─── Phase 2 (post go-live) ───
# ANTHROPIC_API_KEY=
# LOOM_API_KEY=
# WHATSAPP_BUSINESS_ID=
# WHATSAPP_ACCESS_TOKEN=
