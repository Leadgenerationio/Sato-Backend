# ─── Core ───
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
JWT_SECRET=your-jwt-secret-min-32-chars-long-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long

# ─── Data stores ───
DATABASE_URL=postgresql://user:password@localhost:5432/stato
REDIS_URL=redis://localhost:6379

# ─── Xero (accounting) ───
# developer.xero.com/app/manage → Stato app
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3001/api/v1/integrations/xero/callback
XERO_WEBHOOK_KEY=

# ─── LeadByte (lead generation) ───
# Docs: shared by Sam in the credentials handover
LEADBYTE_API_KEY=
LEADBYTE_BASE_URL=https://clinical.leadbyte.co.uk/restapi/v1.3

# ─── Credit checks ───
# Auto-selected at runtime: Creditsafe > Endole > mock.
# Endole — set only if Sam confirms his plan has API access
ENDOLE_API_KEY=
# Creditsafe — recommended alternative. Accepts three credential formats:
#   token:<long-lived-token>   — for accounts with pre-issued tokens
#   <username>:<password>      — OAuth2 exchange via POST /v1/authenticate
#   <raw-api-key>              — some accounts use a long-lived API key directly
CREDITSAFE_API_KEY=
CREDITSAFE_BASE_URL=https://connect.creditsafe.com

# ─── Cloudflare R2 (file storage) ───
# dash.cloudflare.com → R2 → API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=stato-production
R2_PUBLIC_URL=
R2_ENDPOINT=

# ─── Resend (transactional email) ───
# resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@leadgeneration.io
RESEND_FROM_NAME=Stato Notifications

# ─── DocuSign (e-signatures) ───
# Google eSignature has no API; DocuSign is the fallback
# Sandbox: developers.docusign.com; Production: account.docusign.com
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_REDIRECT_URI=http://localhost:3001/api/v1/integrations/docusign/callback
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_OAUTH_BASE=account-d.docusign.com
DOCUSIGN_WEBHOOK_SECRET=

# ─── Catchr (ad-spend aggregation via MCP) ───
# MCP endpoint — overridable if Catchr routes to a regional host
CATCHR_MCP_URL=https://api.catchr.io/mcp
# OAuth bearer token — obtain once via the MCP client authorization flow
# (scope: mcp:tools:read mcp:tools:execute) and paste here for Phase 1.
# Phase-2 work: swap for refresh-token-based rotation.
CATCHR_ACCESS_TOKEN=
# How many days back the first backfill pulls (forward-only after that)
CATCHR_SYNC_BACKFILL_DAYS=30

# ─── Phase 2 (post go-live) ───
# Uncomment when Phase 2 starts
# ANTHROPIC_API_KEY=
# LOOM_API_KEY=
# WHATSAPP_BUSINESS_ID=
# WHATSAPP_ACCESS_TOKEN=
