# ─── Core ───
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allow-listed origins for CORS. REQUIRED in production.
# In dev, the localhost defaults (5173, 5174, 3000) are auto-added in addition.
# Example: CORS_ORIGINS=https://stato.app,https://app.stato.app
CORS_ORIGINS=
# Generate prod values with: openssl rand -base64 32
# In NODE_ENV=production the server fails fast if these still equal the dev defaults.
JWT_SECRET=your-jwt-secret-min-32-chars-long-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long

# ─── Data stores ───
# REQUIRED in production — server refuses to boot if unset (config/database.ts).
DATABASE_URL=postgresql://user:password@localhost:5432/stato
# When unset, all scheduled jobs (chase-overdue daily, leadbyte-sync /2min,
# catchr-sync hourly) are silently skipped — required for production.
REDIS_URL=redis://localhost:6379

# ─── Auto-seed (used by Dockerfile CMD on every container start) ───
# `db:seed-if-empty` runs on container boot. If the users table is empty, it
# inserts the four internal users with these passwords. If the users table
# already has rows, it's a no-op (existing users are never modified).
#
# In NODE_ENV=production, SEED_OWNER_PASSWORD is REQUIRED — the seeder
# refuses to fall back to the dev default ("owner123") and exits non-zero
# if it's empty. The other three default to dev passwords for convenience
# but should be set explicitly in production too.
SEED_OWNER_PASSWORD=
SEED_FINANCE_PASSWORD=
SEED_OPS_PASSWORD=
SEED_READONLY_PASSWORD=

# ─── Manual seed (only used by `pnpm db:seed`) ───
# Set to "true" to seed Apex Media Ltd demo client + sample notifications.
# NEVER enable in any tenant a real user can sign into.
SEED_DEMO_DATA=
SEED_DEMO_CLIENT_PASSWORD=

# ─── Xero (accounting) — Custom Connection ───
# developer.xero.com/app/manage → Stato Custom Connection
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_WEBHOOK_KEY=
# HMRC VAT quarter stagger: 1=MAR/JUN/SEP/DEC (default), 2=APR/JUL/OCT/JAN, 3=MAY/AUG/NOV/FEB
XERO_VAT_STAGGER=1

# ─── LeadByte (lead generation) ───
LEADBYTE_API_KEY=
LEADBYTE_BASE_URL=https://clinical.leadbyte.co.uk/restapi/v1.3

# ─── Credit checks ───
# Auto-selected at runtime: Creditsafe > Endole > mock fallback.
ENDOLE_APP_ID=
ENDOLE_APP_KEY=
ENDOLE_BASE_URL=https://api.endole.co.uk
# Set to "true" for sandbox; leave unset for production billing-charged calls.
ENDOLE_SANDBOX=true
CREDITSAFE_API_KEY=
CREDITSAFE_BASE_URL=https://connect.creditsafe.com

# ─── Cloudflare R2 (file storage) ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=stato-production
R2_PUBLIC_URL=
R2_ENDPOINT=

# ─── Resend (transactional email) ───
RESEND_API_KEY=
# Must match a domain verified in Resend. `notifications@stato.local` is invalid.
RESEND_FROM_EMAIL=notifications@leadgeneration.io
RESEND_FROM_NAME=Stato Notifications

# ─── SignNow (e-signatures, replaces DocuSign) ───
# Default base URL is the production endpoint. Set api-eval.signnow.com for sandbox.
SIGNNOW_CLIENT_ID=
SIGNNOW_CLIENT_SECRET=
# IMPORTANT: SIGNNOW_USERNAME is the email shown as "from" on every signature
# invite the recipient sees. Use a generic mailbox like signing@stato.app — NOT
# a personal staff email. SignNow's API requires `from` to match the
# authenticated account, so changing the displayed sender means re-keying the
# SignNow account itself, not just an env tweak.
SIGNNOW_USERNAME=
SIGNNOW_PASSWORD=
SIGNNOW_BASE_URL=https://api.signnow.com
SIGNNOW_WEBHOOK_SECRET=

# ─── Catchr (ad-spend aggregation via MCP) ───
CATCHR_MCP_URL=https://api.catchr.io/mcp
CATCHR_ACCESS_TOKEN=
CATCHR_SYNC_BACKFILL_DAYS=30

# ─── Phase 2 (post go-live) ───
# Anthropic Messages API — powers in-app AI features:
#   - AI new-task button (Sam #91, ai-task.service.ts)
#   - SOP generation from a Loom transcript (Sam #101, /sops/generate-from-loom)
# Get a key at https://console.anthropic.com. Without this the AI endpoints
# return 503 and the UI falls back to manual forms.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Attio bulk import (Sam #39). Bearer token from Attio API settings.
ATTIO_API_KEY=
ATTIO_BASE_URL=https://api.attio.com/v2
# LOOM_API_KEY=
# WHATSAPP_BUSINESS_ID=
# WHATSAPP_ACCESS_TOKEN=
# Slice 5 Day 6 — SOS WhatsApp button recipient.
# Sam's number (confirmed 13 May 2026): 447776531268. Set this on Railway
# to activate the wa.me deep-link. Until set, the SOS button still records
# the request server-side but doesn't open WhatsApp.
SOS_WHATSAPP_NUMBER=447776531268
